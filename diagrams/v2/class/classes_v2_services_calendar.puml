interface CalendarService <<Service>> {
    + createTask(userId: UUID, req: TaskRequest): TaskResponse
    + getTasks(userId: UUID): List<TaskResponse>
    + getTask(id: UUID): TaskResponse
    + updateTask(id: UUID,\n req: TaskRequest): TaskResponse
