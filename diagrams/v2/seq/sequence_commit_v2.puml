@startuml
skinparam monochrome true
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam ParticipantBackgroundColor transparent

autonumber "<b>[0]</b>"

actor "Пользователь" as User
participant "Интерфейс" as UI
participant "AgentController" as Ctrl
participant "DraftService" as Draft
database "PostgreSQL" as DB

== Подтверждение черновика ==

User -> UI : Нажимает\n "Подтвердить"
activate UI
UI -> Ctrl : POST\n /agent/draft/commit
activate Ctrl
Ctrl -> Draft : commitDraft(userId)
activate Draft

Draft -> DB : UPDATE subtasks\nSET status='scheduled'\nWHERE status='draft'
Draft -> DB : DELETE subtasks\nWHERE status='pending_delete'
Draft -> DB : UPDATE timeslots\nSET is_committed=true

DB --> Draft : OK (транзакция)
Draft --> Ctrl : List<Subtask>
deactivate Draft

Ctrl --> UI : 200 OK {subtasks[]}
deactivate Ctrl
UI --> User : Обновление\n календаря
deactivate UI

== Отклонение черновика (альтернатива) ==

User -> UI : Нажимает\n "Отклонить"
activate UI
UI -> Ctrl : POST\n /agent/draft/reject
activate Ctrl
Ctrl -> Draft : rejectDraft(userId)
activate Draft

Draft -> DB : DELETE subtasks\nWHERE status='draft'
Draft -> DB : UPDATE subtasks\nSET status='scheduled'\nWHERE status='pending_delete'
Draft -> DB : DELETE timeslots\nWHERE is_committed=false

DB --> Draft : OK (транзакция)
Draft --> Ctrl : void
deactivate Draft

Ctrl --> UI : 204 No Content
deactivate Ctrl
UI --> User : Возврат к\n текущему расписанию
deactivate UI

@enduml
